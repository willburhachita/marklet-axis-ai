# ===========================================
# MarketAxis AI — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values

# Convex (auto-filled by `npx convex dev`)
VITE_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Better Auth (set on Convex via `npx convex env set`)
# BETTER_AUTH_SECRET=<generated via openssl rand -base64 32>
# SITE_URL=http://localhost:5173

# Google OAuth (set on Convex dashboard)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth (set on Convex dashboard)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Google Gemini API (set on Convex dashboard)
# GOOGLE_GEMINI_API_KEY=

# Composio (set on Convex dashboard)
# COMPOSIO_API_KEY=
